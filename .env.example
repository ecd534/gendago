# ============================================================================
# GENDAGO - Variáveis de ambiente
# ============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env com dados reais.
# ============================================================================

# ---- [Dev] servidor local ----------------------------------------------------
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-dev-only

# ---- [Dev] banco local (variáveis discretas) ---------------------------------
# Usadas quando DATABASE_URL não está definida
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gendago
DB_USER=postgres
DB_PASSWORD=change-me
DB_SSLMODE=disable

# ---- [Prod] banco Neon -------------------------------------------------------
# Use o direct connection string para rodar migrations (não o pooled):
#   node scripts/run-migrations.js
# Use o pooled connection string no app em produção (variável abaixo).
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.neon.tech/gendago?sslmode=require

# ---- [Prod] Vercel -----------------------------------------------------------
# NODE_ENV=production
# SESSION_SECRET=string-aleatoria-forte-minimo-32-caracteres
# ALLOWED_ORIGIN=https://seu-projeto.vercel.app
