<!DOCTYPE html>
<html lang="pt-BR">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> | Gendago</title>
	<link rel="preconnect" href="https://cdn.jsdelivr.net">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
	<link rel="stylesheet" href="/styles/webapp-store.css">
	<link rel="stylesheet" href="/styles/webapp-error.css">
</head>
<body class="error-page-body">
	<main class="error-page-wrapper">
		<section class="error-card" role="status" aria-live="polite">
			<img
				src="/images/error.jpg"
				alt="Ilustracao de indisponibilidade temporaria"
				class="error-image">

			<p class="error-code"><%= statusCode %></p>
			<h1 class="error-title">Estamos trabalhando nisso por aqui ...</h1>
			<p class="error-message"><%= message %></p>

			<div class="error-actions">
				<a class="btn btn-outline-secondary btn-error" href="<%= backUrl %>">Tentar novamente</a>
				<a class="btn btn-dark btn-error" href="/">Ir para inicio</a>
			</div>
		</section>
	</main>
</body>
</html>
