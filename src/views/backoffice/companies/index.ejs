<!DOCTYPE html>
<html lang="pt-BR">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> | Gendago</title>
	<link rel="preconnect" href="https://cdn.jsdelivr.net">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
	<link rel="stylesheet" href="/styles/admin.css">
</head>
<body>
	<div class="container-fluid backoffice-shell" id="company-page"
		data-create-company-endpoint="/admin/api/empresas"
		data-company-detail-endpoint-template="/admin/api/empresas/__COMPANY_ID__"
		data-company-update-endpoint-template="/admin/api/empresas/__COMPANY_ID__"
		data-can-create-company="<%= canCreateCompany ? 'true' : 'false' %>">
		<div class="row min-vh-100">
			<%- include('../partials/sidebar', { currentAdmin, page }) %>

			<main class="col-12 col-lg-9 col-xl-10 content-wrap">
				<section class="glass-card p-4 p-xl-5 mb-4">
					<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
						<div>
							<p class="text-uppercase small fw-semibold text-secondary mb-2">Cadastro</p>
							<h1 class="display-6 fw-semibold mb-2">Empresas</h1>
							<p class="text-secondary mb-0">Modulo exclusivo do master para listar, cadastrar e gerenciar rapidamente o status das empresas.</p>
						</div>
						<% if (canCreateCompany) { %>
							<button type="button" class="btn btn-dark rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createCompanyModal">Nova empresa</button>
						<% } %>
					</div>
				</section>

				<% if (flashMessage) { %>
					<div class="alert alert-<%= flashMessage.type %> border-0 rounded-4 mb-4" role="alert"><%= flashMessage.text %></div>
				<% } %>

				<section class="glass-card p-4">
					<div class="table-responsive">
						<table class="table align-middle admin-table mb-0">
							<thead>
								<tr>
									<th>Empresa</th>
									<th>Contato</th>
									<th>Slug</th>
									<th>Status</th>
									<th class="text-end">Acoes</th>
								</tr>
							</thead>
							<tbody>
								<% companies.forEach((company) => { %>
									<tr>
										<td data-label="Empresa">
											<div class="d-flex align-items-center gap-2">
												<% if (company.logo_empresa) { %>
													<img src="<%= company.logo_empresa %>" alt="Logo <%= company.nome %>" class="company-row-logo">
												<% } %>
												<div class="fw-semibold"><%= company.nome %></div>
											</div>
											<div class="small text-secondary"><%= company.endereco || 'Endereco nao informado' %></div>
											<div class="small text-secondary"><%= company.id %></div>
										</td>
										<td data-label="Contato">
											<div><%= company.telefone || 'Telefone nao informado' %></div>
											<div class="small text-secondary"><%= company.email || 'E-mail nao informado' %></div>
										</td>
										<td data-label="Slug"><%= company.slug || 'Sem slug' %></td>
										<td data-label="Status">
											<span class="badge rounded-pill <%= company.status === 'Ativa' ? 'badge-status-active' : 'badge-status-inactive' %>">
												<%= company.status %>
											</span>
										</td>
										<td data-label="Acoes">
											<div class="d-flex justify-content-end gap-2 flex-wrap">
												<button type="button" class="btn btn-sm btn-outline-dark rounded-pill manage-company-button"
													data-bs-toggle="modal"
													data-bs-target="#manageCompanyModal"
													data-company-id="<%= company.id %>"
													data-company-name="<%- company.nome %>">
													Gerenciar
												</button>
											</div>
										</td>
									</tr>
								<% }) %>
							</tbody>
						</table>
					</div>
				</section>
			</main>
		</div>
	</div>

	<% if (canCreateCompany) { %>
	<div class="modal fade" id="createCompanyModal" tabindex="-1" aria-labelledby="createCompanyModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-lg">
			<div class="modal-content border-0 rounded-4">
				<div class="modal-header border-0 pb-0">
					<div>
						<h2 class="modal-title h4 mb-1" id="createCompanyModalLabel">Nova empresa</h2>
						<p class="text-secondary mb-0">Cadastre os dados da empresa no mesmo fluxo da listagem.</p>
					</div>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
				</div>
				<div class="modal-body pt-4">
					<div id="create-company-feedback" class="alert d-none rounded-4 border-0" role="alert"></div>
					<form id="create-company-form" class="row g-3">
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="new-company-name">Nome</label>
							<input class="form-control admin-input" id="new-company-name" name="nome" required>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="new-company-slug">Slug</label>
							<input class="form-control admin-input" id="new-company-slug" name="slug" required>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="new-company-phone">Telefone</label>
							<input class="form-control admin-input" id="new-company-phone" name="telefone" required>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="new-company-email">E-mail</label>
							<input type="email" class="form-control admin-input" id="new-company-email" name="email">
						</div>
						<div class="col-12">
							<label class="form-label fw-semibold" for="new-company-address">Endereco</label>
							<textarea class="form-control admin-input admin-textarea" id="new-company-address" name="endereco" rows="3" required></textarea>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="new-company-status">Status</label>
							<select class="form-select admin-input" id="new-company-status" name="status">
								<option value="Ativa" selected>Ativa</option>
								<option value="Inativa">Inativa</option>
							</select>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="new-company-logo">Logo da empresa (max 192x192)</label>
							<input type="file" class="form-control admin-input" id="new-company-logo" accept="image/*">
							<input type="hidden" id="new-company-logo-base64" name="logo_empresa">
							<div class="form-text">A imagem sera salva em base64.</div>
							<div class="company-logo-preview-wrap mt-2">
								<img id="new-company-logo-preview" class="company-logo-preview d-none" alt="Preview da logo">
							</div>
						</div>
						<div class="col-12 d-flex justify-content-end gap-2 pt-2">
							<button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
							<button type="submit" class="btn btn-dark rounded-pill px-4">Criar empresa</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
	<% } %>

	<div class="modal fade" id="manageCompanyModal" tabindex="-1" aria-labelledby="manageCompanyModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-lg">
			<div class="modal-content border-0 rounded-4">
				<div class="modal-header border-0 pb-0">
					<div>
						<h2 class="modal-title h4 mb-1" id="manageCompanyModalLabel">Gerenciar empresa</h2>
						<p class="text-secondary mb-0" id="manageCompanySubtitle">Atualize os dados da empresa sem sair da listagem.</p>
					</div>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
				</div>
				<div class="modal-body pt-4">
					<div id="manage-company-feedback" class="alert d-none rounded-4 border-0" role="alert"></div>
					<form id="manage-company-form" class="row g-3">
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="manage-company-name">Nome</label>
							<input class="form-control admin-input" id="manage-company-name" name="nome">
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="manage-company-slug">Slug</label>
							<input class="form-control admin-input" id="manage-company-slug" name="slug" readonly>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="manage-company-phone">Telefone</label>
							<input class="form-control admin-input" id="manage-company-phone" name="telefone">
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="manage-company-email">E-mail</label>
							<input class="form-control admin-input" id="manage-company-email" name="email">
						</div>
						<div class="col-12">
							<label class="form-label fw-semibold" for="manage-company-address">Endereco</label>
							<textarea class="form-control admin-input admin-textarea" id="manage-company-address" name="endereco" rows="3"></textarea>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="manage-company-status">Status</label>
							<select class="form-select admin-input" id="manage-company-status" name="status">
								<option value="Ativa">Ativa</option>
								<option value="Inativa">Inativa</option>
							</select>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="manage-company-logo">Logo da empresa (max 192x192)</label>
							<input type="file" class="form-control admin-input" id="manage-company-logo" accept="image/*">
							<input type="hidden" id="manage-company-logo-base64" name="logo_empresa">
							<div class="company-logo-preview-wrap mt-2">
								<img id="manage-company-logo-preview" class="company-logo-preview d-none" alt="Preview da logo">
							</div>
						</div>
						<div class="col-12 d-flex justify-content-end gap-2 pt-2">
							<button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
							<button type="submit" class="btn btn-dark rounded-pill px-4">Salvar alteracoes</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
	<script>
		(function () {
			const page = document.getElementById('company-page');
			if (!page) {
				return;
			}

			const createCompanyForm = document.getElementById('create-company-form');
			const createFeedback = document.getElementById('create-company-feedback');
			const manageCompanyForm = document.getElementById('manage-company-form');
			const manageFeedback = document.getElementById('manage-company-feedback');
			const manageSubtitle = document.getElementById('manageCompanySubtitle');
			const createLogoInput = document.getElementById('new-company-logo');
			const createLogoBase64Input = document.getElementById('new-company-logo-base64');
			const createLogoPreview = document.getElementById('new-company-logo-preview');
			const manageLogoInput = document.getElementById('manage-company-logo');
			const manageLogoBase64Input = document.getElementById('manage-company-logo-base64');
			const manageLogoPreview = document.getElementById('manage-company-logo-preview');

			let selectedCompanyId = '';

			function setFeedback(element, type, text) {
				if (!element) {
					return;
				}

				if (!text) {
					element.className = 'alert d-none rounded-4 border-0';
					element.textContent = '';
					return;
				}

				element.className = `alert alert-${type} rounded-4 border-0`;
				element.textContent = text;
			}

			function parseResponse(response) {
				return response.text().then((text) => {
					try {
						return text ? JSON.parse(text) : {};
					} catch (error) {
						return { message: text || 'Resposta invalida da API.' };
					}
				});
			}

			function endpointFromTemplate(template, companyId) {
				return String(template || '').replace('__COMPANY_ID__', encodeURIComponent(companyId));
			}

			function setLogoPreview(imageElement, value) {
				if (!imageElement) {
					return;
				}

				if (!value) {
					imageElement.src = '';
					imageElement.classList.add('d-none');
					return;
				}

				imageElement.src = value;
				imageElement.classList.remove('d-none');
			}

			async function fileToBase64(file) {
				return new Promise((resolve, reject) => {
					const reader = new FileReader();
					reader.onload = () => resolve(String(reader.result || ''));
					reader.onerror = () => reject(new Error('Nao foi possivel ler a imagem selecionada.'));
					reader.readAsDataURL(file);
				});
			}

			async function validateAndStoreLogo(fileInput, hiddenInput, previewImage, feedbackElement) {
				const [file] = fileInput && fileInput.files ? fileInput.files : [];
				if (!file) {
					hiddenInput.value = '';
					setLogoPreview(previewImage, '');
					return;
				}

				const base64 = await fileToBase64(file);
				const dimensions = await new Promise((resolve, reject) => {
					const img = new Image();
					img.onload = () => resolve({ width: img.naturalWidth, height: img.naturalHeight });
					img.onerror = () => reject(new Error('Arquivo de imagem invalido.'));
					img.src = base64;
				});

				if (dimensions.width > 192 || dimensions.height > 192) {
					fileInput.value = '';
					hiddenInput.value = '';
					setLogoPreview(previewImage, '');
					setFeedback(feedbackElement, 'warning', 'A logo deve ter no maximo 192x192 pixels.');
					return;
				}

				hiddenInput.value = base64;
				setLogoPreview(previewImage, base64);
			}

			if (createLogoInput && createLogoBase64Input) {
				createLogoInput.addEventListener('change', async () => {
					try {
						await validateAndStoreLogo(createLogoInput, createLogoBase64Input, createLogoPreview, createFeedback);
					} catch (error) {
						setFeedback(createFeedback, 'danger', error.message || 'Nao foi possivel processar a imagem da logo.');
					}
				});
			}

			if (manageLogoInput && manageLogoBase64Input) {
				manageLogoInput.addEventListener('change', async () => {
					try {
						await validateAndStoreLogo(manageLogoInput, manageLogoBase64Input, manageLogoPreview, manageFeedback);
					} catch (error) {
						setFeedback(manageFeedback, 'danger', error.message || 'Nao foi possivel processar a imagem da logo.');
					}
				});
			}

			if (createCompanyForm) {
				createCompanyForm.addEventListener('submit', async (event) => {
					event.preventDefault();
					setFeedback(createFeedback, null, '');

					const formData = new FormData(createCompanyForm);
					const payload = {
						nome: String(formData.get('nome') || '').trim(),
						slug: String(formData.get('slug') || '').trim(),
						telefone: String(formData.get('telefone') || '').trim(),
						email: String(formData.get('email') || '').trim(),
						endereco: String(formData.get('endereco') || '').trim(),
						status: String(formData.get('status') || 'Ativa').trim(),
						logo_empresa: String(formData.get('logo_empresa') || '').trim(),
					};

					if (!payload.nome || !payload.slug || !payload.telefone || !payload.endereco) {
						setFeedback(createFeedback, 'warning', 'Preencha nome, slug, telefone e endereco para continuar.');
						return;
					}

					try {
						const response = await fetch(page.dataset.createCompanyEndpoint, {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json',
								Accept: 'application/json',
							},
							body: JSON.stringify(payload),
						});

						const result = await parseResponse(response);
						if (!response.ok) {
							throw new Error(result.message || 'Nao foi possivel criar a empresa.');
						}

						setFeedback(createFeedback, 'success', 'Empresa criada com sucesso.');
						setTimeout(() => {
							window.location.reload();
						}, 400);
					} catch (error) {
						setFeedback(createFeedback, 'danger', error.message || 'Nao foi possivel criar a empresa.');
					}
				});
			}

			document.querySelectorAll('.manage-company-button').forEach((button) => {
				button.addEventListener('click', async () => {
					selectedCompanyId = button.dataset.companyId || '';
					const companyName = button.dataset.companyName || 'Empresa';
					manageSubtitle.textContent = `Atualize os dados da empresa ${companyName}.`;
					setFeedback(manageFeedback, null, '');

					try {
						const detailEndpoint = endpointFromTemplate(page.dataset.companyDetailEndpointTemplate, selectedCompanyId);
						const response = await fetch(detailEndpoint, { headers: { Accept: 'application/json' } });
						const result = await parseResponse(response);

						if (!response.ok) {
							throw new Error(result.message || 'Nao foi possivel carregar a empresa.');
						}

						manageCompanyForm.querySelector('#manage-company-name').value = result.nome || '';
						manageCompanyForm.querySelector('#manage-company-slug').value = result.slug || '';
						manageCompanyForm.querySelector('#manage-company-phone').value = result.telefone || '';
						manageCompanyForm.querySelector('#manage-company-email').value = result.email || '';
						manageCompanyForm.querySelector('#manage-company-address').value = result.endereco || '';
						manageCompanyForm.querySelector('#manage-company-status').value = result.status || 'Ativa';
						manageCompanyForm.querySelector('#manage-company-logo-base64').value = result.logo_empresa || '';
						if (manageLogoInput) {
							manageLogoInput.value = '';
						}
						setLogoPreview(manageLogoPreview, result.logo_empresa || '');
					} catch (error) {
						setFeedback(manageFeedback, 'danger', error.message || 'Nao foi possivel carregar a empresa.');
					}
				});
			});

			if (manageCompanyForm) {
				manageCompanyForm.addEventListener('submit', async (event) => {
					event.preventDefault();
					setFeedback(manageFeedback, null, '');

					if (!selectedCompanyId) {
						setFeedback(manageFeedback, 'warning', 'Selecione uma empresa para continuar.');
						return;
					}

					const payload = {
						nome: String(manageCompanyForm.querySelector('#manage-company-name').value || '').trim(),
						telefone: String(manageCompanyForm.querySelector('#manage-company-phone').value || '').trim(),
						email: String(manageCompanyForm.querySelector('#manage-company-email').value || '').trim(),
						endereco: String(manageCompanyForm.querySelector('#manage-company-address').value || '').trim(),
						status: String(manageCompanyForm.querySelector('#manage-company-status').value || 'Ativa').trim(),
						logo_empresa: String(manageCompanyForm.querySelector('#manage-company-logo-base64').value || '').trim(),
					};

					if (!payload.nome || !payload.telefone || !payload.endereco) {
						setFeedback(manageFeedback, 'warning', 'Preencha nome, telefone e endereco para continuar.');
						return;
					}

					try {
						const updateEndpoint = endpointFromTemplate(page.dataset.companyUpdateEndpointTemplate, selectedCompanyId);
						const response = await fetch(updateEndpoint, {
							method: 'PATCH',
							headers: {
								'Content-Type': 'application/json',
								Accept: 'application/json',
							},
							body: JSON.stringify(payload),
						});

						const result = await parseResponse(response);
						if (!response.ok) {
							throw new Error(result.message || 'Nao foi possivel atualizar o status da empresa.');
						}

						setFeedback(manageFeedback, 'success', 'Empresa atualizada com sucesso.');
						setTimeout(() => {
							window.location.reload();
						}, 400);
					} catch (error) {
						setFeedback(manageFeedback, 'danger', error.message || 'Nao foi possivel atualizar a empresa.');
					}
				});
			}
		}());
	</script>
</body>
</html>