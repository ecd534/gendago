<!DOCTYPE html>
<html lang="pt-BR">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> | Gendago</title>
	<link rel="preconnect" href="https://cdn.jsdelivr.net">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
	<link rel="stylesheet" href="/styles/admin.css">
</head>
<body>
	<div class="container-fluid backoffice-shell">
		<div class="row min-vh-100">
			<%- include('../partials/sidebar', { currentAdmin, page }) %>

			<main class="col-12 col-lg-9 col-xl-10 content-wrap">
				<section class="glass-card p-4 p-xl-5 mb-4">
					<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
						<div>
							<p class="text-uppercase small fw-semibold text-secondary mb-2">Cadastro</p>
							<h1 class="display-6 fw-semibold mb-2"><%= formMode === 'create' ? 'Nova empresa' : 'Editar empresa' %></h1>
							<p class="text-secondary mb-0"><%= formMode === 'create' ? 'Cadastre uma nova empresa usando os campos exigidos pela API atual.' : 'Consulte os dados atuais da empresa e altere principalmente o seu status.' %></p>
						</div>
						<a href="/admin/empresas" class="btn btn-outline-dark rounded-pill px-4">Voltar</a>
					</div>
				</section>

				<% if (formError) { %>
					<div class="alert alert-danger border-0 rounded-4 mb-4" role="alert"><%= formError %></div>
				<% } %>

				<% if (formMode === 'edit') { %>
					<div class="alert alert-warning border-0 rounded-4 mb-4" role="alert">O endpoint atual de empresas permite atualizacao direta de status. Os demais dados ficam visiveis para conferencia nesta tela.</div>
				<% } %>

				<section class="glass-card p-4 p-xl-5">
					<form action="<%= formAction %>" method="post" class="row g-4">
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="nome">Nome</label>
							<input class="form-control form-control-lg admin-input" id="nome" name="nome" value="<%= companyForm.nome %>" <%= formMode === 'create' ? 'required' : 'readonly' %>>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="slug">Slug</label>
							<input class="form-control form-control-lg admin-input" id="slug" name="slug" value="<%= companyForm.slug %>" <%= formMode === 'create' ? 'required' : 'readonly' %>>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="telefone">Telefone</label>
							<input class="form-control form-control-lg admin-input" id="telefone" name="telefone" value="<%= companyForm.telefone %>" <%= formMode === 'create' ? 'required' : 'readonly' %>>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="email">E-mail</label>
							<input type="email" class="form-control form-control-lg admin-input" id="email" name="email" value="<%= companyForm.email %>" <%= formMode === 'edit' ? 'readonly' : '' %>>
						</div>
						<div class="col-12">
							<label class="form-label fw-semibold" for="endereco">Endereco</label>
							<textarea class="form-control form-control-lg admin-input admin-textarea" id="endereco" name="endereco" rows="4" <%= formMode === 'create' ? 'required' : 'readonly' %>><%= companyForm.endereco %></textarea>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="status">Status</label>
							<select class="form-select form-select-lg admin-input" id="status" name="status">
								<option value="Ativa" <%= companyForm.status === 'Ativa' ? 'selected' : '' %>>Ativa</option>
								<option value="Inativa" <%= companyForm.status === 'Inativa' ? 'selected' : '' %>>Inativa</option>
							</select>
							<div class="form-text"><%= formMode === 'create' ? 'A nova empresa pode nascer ativa ou inativa.' : 'A alteracao de status usa o endpoint PATCH ja existente.' %></div>
						</div>
						<div class="col-12 d-flex justify-content-end gap-2 pt-2">
							<a href="/admin/empresas" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
							<button type="submit" class="btn btn-dark rounded-pill px-4"><%= formMode === 'create' ? 'Criar empresa' : 'Salvar status' %></button>
						</div>
					</form>
				</section>
			</main>
		</div>
	</div>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
</body>
</html>