<!DOCTYPE html>
<html lang="pt-BR">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> | Gendago</title>
	<link rel="preconnect" href="https://cdn.jsdelivr.net">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
	<link rel="stylesheet" href="/styles/admin.css">
</head>
<body>
	<div class="container-fluid backoffice-shell">
		<div class="row min-vh-100">
			<%- include('../partials/sidebar', { currentAdmin, page }) %>

			<main class="col-12 col-lg-9 col-xl-10 content-wrap">
				<section class="glass-card p-4 p-xl-5 mb-4">
					<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
						<div>
							<p class="text-uppercase small fw-semibold text-secondary mb-2">Cadastro</p>
							<h1 class="display-6 fw-semibold mb-2"><%= formMode === 'create' ? 'Novo usuario' : 'Editar usuario' %></h1>
							<p class="text-secondary mb-0">Gerencie nome, email, nivel, empresa e status do usuario.</p>
						</div>
						<a href="/admin/usuarios" class="btn btn-outline-dark rounded-pill px-4">Voltar</a>
					</div>
				</section>

				<% if (formError) { %>
					<div class="alert alert-danger border-0 rounded-4 mb-4" role="alert"><%= formError %></div>
				<% } %>

				<section class="glass-card p-4 p-xl-5">
					<form action="<%= formAction %>" method="post" class="row g-4">
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="nome">Nome</label>
							<input class="form-control form-control-lg admin-input" id="nome" name="nome" value="<%= userForm.nome %>" required>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="email">E-mail</label>
							<input type="email" class="form-control form-control-lg admin-input" id="email" name="email" value="<%= userForm.email %>" required>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="nivel">Nivel</label>
							<select class="form-select form-select-lg admin-input" id="nivel" name="nivel" required>
								<% levelOptions.forEach((level) => { %>
									<option value="<%= level %>" <%= userForm.nivel === level ? 'selected' : '' %>><%= level %></option>
								<% }) %>
							</select>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="empresa_id">Empresa</label>
							<% if (isMaster) { %>
								<select class="form-select form-select-lg admin-input" id="empresa_id" name="empresa_id">
									<option value="" <%= !selectedCompanyId ? 'selected' : '' %>>Global (sem empresa)</option>
									<% (activeCompanies || []).forEach((company) => { %>
										<option value="<%= company.id %>" <%= selectedCompanyId === company.id ? 'selected' : '' %>><%= company.nome %></option>
									<% }) %>
								</select>
							<% } else { %>
								<input type="hidden" name="empresa_id" value="<%= selectedCompanyId || userForm.empresa_id %>">
								<input class="form-control form-control-lg admin-input company-name-input" value="<%= selectedCompanyName || 'Sem empresa vinculada' %>" readonly>
							<% } %>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="senha">Senha</label>
							<input type="password" class="form-control form-control-lg admin-input" id="senha" name="senha" minlength="6" <%= formMode === 'create' ? 'required' : '' %>>
							<div class="form-text"><%= formMode === 'create' ? 'Informe pelo menos 6 caracteres.' : 'Preencha apenas se desejar trocar a senha.' %></div>
						</div>
						<div class="col-12 col-md-6">
							<label class="form-label fw-semibold" for="ativo">Status</label>
							<select class="form-select form-select-lg admin-input" id="ativo" name="ativo">
								<option value="true" <%= userForm.ativo ? 'selected' : '' %>>Ativo</option>
								<option value="false" <%= !userForm.ativo ? 'selected' : '' %>>Inativo</option>
							</select>
						</div>
						<div class="col-12 d-flex justify-content-end gap-2 pt-2">
							<a href="/admin/usuarios" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
							<button type="submit" class="btn btn-dark rounded-pill px-4"><%= formMode === 'create' ? 'Criar usuario' : 'Salvar alteracoes' %></button>
						</div>
					</form>
				</section>
			</main>
		</div>
	</div>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
</body>
</html>