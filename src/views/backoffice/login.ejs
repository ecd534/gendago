<!DOCTYPE html>
<html lang="pt-BR">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> | GendaGO</title>
	<link rel="preconnect" href="https://cdn.jsdelivr.net">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
	<link rel="stylesheet" href="/styles/admin-login.css">
</head>
<body>
	<main class="login-shell container-fluid px-3 px-md-4">
		<div class="row align-items-center justify-content-center min-vh-100 py-5 g-4">
			<div class="col-12 col-lg-5 col-xl-4">
				<section class="login-panel p-4 p-md-5">
					<div class="d-flex align-items-center gap-3 mb-4">
						<div class="login-brand-mark">G</div>
						<div>
							<div class="fw-semibold fs-5">GendaGO</div>
							<div class="text-secondary small">Painel Administrador</div>
						</div>
					</div>

					<p class="login-kicker mb-2">Acesso seguro</p>
					<p class="text-secondary mb-4">Use seu e-mail corporativo e senha para acessar cadastros, operacoes e relatorios.</p>

					<% if (errorMessage) { %>
						<div class="alert alert-danger border-0 rounded-4 py-3 px-3 mb-4" role="alert">
							<strong>Atenção, email ou senha são inválidos</strong>
						</div>
					<% } %>

					<form action="/admin/login" method="post" class="d-grid gap-3">
						<div>
							<label for="email" class="form-label fw-semibold">E-mail</label>
							<input
								type="email"
								class="form-control form-control-lg login-input"
								id="email"
								name="email"
								value="<%= form.email %>"
								autocomplete="email"
								required
							>
						</div>

						<div>
							<div class="d-flex justify-content-between align-items-center">
								<label for="password" class="form-label fw-semibold">Senha</label>
								<span class="small text-secondary">Minimo de 6 caracteres</span>
							</div>
							<input
								type="password"
								class="form-control form-control-lg login-input"
								id="password"
								name="password"
								autocomplete="current-password"
								minlength="6"
								required
							>
						</div>

						<button type="submit" class="btn btn-dark btn-lg rounded-pill login-submit">Entrar</button>
					</form>
				</section>
			</div>

		</div>
	</main>
</body>
</html>