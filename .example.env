# =============================================================================
# GENDAGO - Environment Variables (Copie para .env local)
# =============================================================================
# IMPORTANTE: Nunca commitar .env no Git! Use .gitignore

# NODE ENVIRONMENT
NODE_ENV=development
PORT=3000

# =============================================================================
# SEGURANÇA (Mude TODOS em produção!)
# =============================================================================

# Session secret (gerar: openssl rand -base64 32)
SESSION_SECRET=seu_random_secret_32_chars_aqui_nao_use_isso

# JWT secret (gerar: openssl rand -base64 32)
SECRET_KEY=seu_jwt_secret_32_chars_aqui_nao_use_isso

# Domínio permitido para CORS (webapp public)
ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# BANCO DE DADOS - PostgreSQL
# =============================================================================

# Local (desenvolvimento)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gendago
DB_USER=postgres
DB_PASSWORD=1234

# Railway (production) - Substitua pelos valores do Railway
# DB_HOST=seu-railway-postgres-host.railway.com
# DB_PORT=5432
# DB_NAME=gendago
# DB_USER=seu_usuario
# DB_PASSWORD=sua_senha_forte_aqui
# DB_SSLMODE=require

# Query timeouts
DB_QUERY_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# =============================================================================
# OPTIONAL: Email (Para notificações - depois implementar)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASSWORD=sua_senha_app_google
# SMTP_FROM_EMAIL=noreply@gendago.com

# =============================================================================
# OPTIONAL: Uptime monitoring (depois implementar)
# =============================================================================
# SENTRY_DSN=https://seu_sentry_dsn_aqui
