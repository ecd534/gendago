{
  "version": 2,
  "builds": [
    {
      "src": "src/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    "functions": {
      "src/app.js": { "maxDuration": 30 }
    },
    {
      "src": "/(.*)",
      "dest": "/src/app.js"
        "use": "@vercel/node",
        "config": { "maxLambdaSize": "15mb" }
  ]
}
